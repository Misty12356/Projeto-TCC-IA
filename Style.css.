/* Configuração Geral: Define a fonte e as cores de fundo */
body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    background-color: #f4f7f6;
    color: #333;
    padding: 20px;
    max-width: 800px;
    margin: 0 auto; /* Centraliza o projeto na tela */
}

/* Estilo do Título Principal */
h1 {
    color: #2c3e50;
    text-align: center;
}

/* Estilo das Tags de Segurança (o topo do site) */
.tags {
    display: flex;
    gap: 10px;
    justify-content: center;
    margin-bottom: 20px;
}

.tag {
    background-color: #e8ecef;
    padding: 5px 12px;
    border-radius: 15px;
    font-size: 0.85em;
    font-weight: bold;
    border: 1px solid #d1d8dd;
}

/* Estilo da Caixa de Texto (Perguntas) */
textarea {
    width: 100%;
    height: 120px;
    padding: 15px;
    border: 2px solid #ddd;
    border-radius: 10px;
    font-size: 16px;
    resize: none; /* Impede o usuário de mudar o tamanho e quebrar o layout */
    box-sizing: border-box; /* Garante que o preenchimento não aumente a largura total */
}

/* Estilo do Grupo de Botões */
.botoes {
    display: flex;
    flex-wrap: wrap; /* Faz os botões pularem de linha em telas pequenas */
    gap: 10px;
    margin-top: 15px;
}

button {
    padding: 10px 20px;
    border: none;
    border-radius: 5px;
    cursor: pointer;
    font-weight: bold;
    transition: background 0.3s; /* Deixa a mudança de cor suave ao passar o mouse */
}

/* Cores específicas para cada botão */
#btn-enviar { background-color: #3498db; color: white; }
#btn-enviar:hover { background-color: #2980b9; }

#btn-br, #btn-pt { background-color: #2ecc71; color: white; }
#btn-br:hover, #btn-pt:hover { background-color: #27ae60; }

#btn-parar { background-color: #e74c3c; color: white; }
#btn-parar:hover { background-color: #c0392b; }

/* O Painel onde a IA responde (Relatório Estratégico) */
.painel-resposta {
    background-color: white;
    border: 1px solid #ddd;
    border-radius: 10px;
    padding: 20px;
    min-height: 150px;
    margin-top: 10px;
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
}
